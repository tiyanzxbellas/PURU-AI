{
  "name": "telegram-ai-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --external:node_modules/* --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.15",
    "@e2b/code-interpreter": "^2.6.1",
    "@langchain/core": "^1.2.3",
    "ai": "^7.0.30",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.34.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
